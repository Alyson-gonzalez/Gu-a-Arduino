int pir = 5; //Nombres de los pines
int led = 8;
int mov; //Variable sin asignación
void setup() {
  pinMode(pir, INPUT); //Se inicializa el pin para que meta la información
  pinMode(led, OUTPUT); //Se inicializa el pin para que saque la información

oled.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS); //Se inicializa la pantalla
oled.clearDisplay(); //Se limpia la pantalla
  oled.display(); //Se muestra en la pantalla la información que reciba
}

void loop(){
  mov = digitalRead(pir); //La variable tendrá el valor de la información que lea del pin
  if (mov == HIGH) { //Condición: Si la variable es igual a la señal PWM 1
    digitalWrite(led, HIGH); //El pin escribe una señal PWM de 1
     oled.clearDisplay(); //La pantalla se limpia
     oled.drawBitmap( //La pantalla dibuja la imagen
      32, 16, //Ubicación de la imagen
      epd_bitmap_gettyimages_2171182324_612x612, //El nombre de la imágen
      64, 48, //Tamaño de la imágen
      SSD1306_WHITE //Color de la imágen
      );
    

    oled.display(); //Que la información se muestre en la pantalla
  }
  else { //Si no se cumple la condición 
    digitalWrite(led, LOW); //El pin escribe una señal PWM de 0
    oled.clearDisplay(); //La pantalla se limpia
    oled.display(); //Se muestra en la pantalla
  }
}
