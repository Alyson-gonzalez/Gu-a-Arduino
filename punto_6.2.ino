SoftwareSerial BT(10, 11); //Nombre de los pines del HC 06
char data = 0; //Actualmente, el char tiene el dato de 0

int ENA = 5; //Nombres de los pines que van al puente H
int IN1 = 2;
int IN2 = 3;
int IN3 = 4;
int IN4 = 7;
int ENB = 6;

void setup() {
  BT.begin(9600);
  pinMode(ENA, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
  pinMode(ENB, OUTPUT);
  Wire.begin();
  oled.begin(SSD1306_SWITCHCAPVCC, SCREEN);

}

void loop() {
  if (BT.available()) { //HC 06 evalúa la información
    data = BT.read(); //El char será igual al texto que lea en el HC 06
    if (data == '1') { //Si el char recibe un texto de 1
      analogWrite(ENA, 45);//El pin escribe una velocidad de 45/255 para el motor 1
      digitalWrite(IN2, HIGH); //Sentido del motor 1 
      digitalWrite(IN4, HIGH); //Sentido del motor 2
      analogWrite(ENB, 45); //El pin escribe una velocidad de 45/255 para el motor 2
      oled.clearDisplay(); //Pantalla oled limpia la pantalla
      oled.drawBitmap(0,0,epd_bitmap_Arriba00001,128,64,WHITE); // Pantalla oled dibuja una imagén en las coordenadas 0,0 con un tamaño de 128, 64
      oled.display();
      delay(70);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Arriba00006,128,64,WHITE);
      oled.display();
      delay(70);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Arriba00011,128,64,WHITE);
      oled.display();
      delay(70);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Arriba00014,128,64,WHITE);
      oled.display();

    }
    
    else if (data == '3') {
      analogWrite(ENA, 50);//DERECHA
      digitalWrite(IN1, LOW);
      digitalWrite(IN2, HIGH);
      analogWrite(ENB, 0);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Derecha00001,128,64,WHITE);
      oled.display();
      delay(70);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Derecha00003,128,64,WHITE);
      oled.display();
      delay(70);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Derecha00015,128,64,WHITE);
      oled.display();
      delay(70);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Derecha00017,128,64,WHITE);
      oled.display();

    }
    else if (data == '5') {
      analogWrite(ENB, 50);//IZQUIERDA
      digitalWrite(IN3, LOW);
      digitalWrite(IN4, HIGH);
      analogWrite(ENA, 0);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Izquierda00001,128,64,WHITE);
      oled.display();
      delay(70);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Izquierda00015,128,64,WHITE);
      oled.display();
      delay(70);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Izquierda00004,128,64,WHITE);
      oled.display();
      delay(70);
      oled.clearDisplay();
      oled.drawBitmap(0,0,epd_bitmap_Izquierda00017,128,64,WHITE);
      oled.display();

    }
    else if (data == '0') {
      analogWrite(ENB, 0);//APAGADO
      analogWrite(ENA, 0);
    }
  }
}
