void setup() {
  oled.begin(SSD1306_SWITCHCAPVCC, Screen); //Se inicializa la pantalla

}

void loop() {
  oled.clearDisplay(); //Se limpia la pantalla
  oled.setTextSize(1); //Tamaño de la letra
  oled.setTextColor(SSD1306_WHITE); //Color de la letra
  oled.setCursor(10,0); //Coordenadas para ubicar el inicio del texto
  oled.println("Centro de Diseno"); //El texto que se va a mostrar en la pantalla

  oled.setCursor(20,10); //Coordenadas para ubicar el inicio del texto
  oled.println("y Metrologia"); //El texto que se va a mostrar en la pantalla

oled.drawBitmap( //Se llama la función para dibujar la imágen
    32, 20,          // Posición X,Y
    logo_sena,       // Bitmap
    64, 44,          // Ancho y alto aproximado
    SSD1306_WHITE
  );

  oled.display(); //Se ordena que se muestre en la pantalla

}
